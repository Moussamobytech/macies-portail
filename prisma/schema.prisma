generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  name          String
  email         String         @unique
  phone         String
  password      String
  role          String         @default("CLIENT") // CLIENT or ADMIN
  createdAt     DateTime       @default(now())
  requests      ServiceRequest[]
  orders        Order[]
  notifications Notification[]
  activityLogs  ActivityLog[]
  messages      Message[]
}

model ServiceRequest {
  id             String   @id @default(uuid())
  type           String
  description    String
  status         String   @default("PENDING") // PENDING, IN_PROGRESS, VALIDATED, DELIVERED
  fileUrl        String?
  deliverableUrl String?
  createdAt      DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  messages    Message[]
}

model Order {
  id            String   @id @default(uuid())
  softwareName  String
  price         String
  paymentStatus String   @default("UNPAID")
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id])
  userId        String
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
}

model ActivityLog {
  id        String   @id @default(uuid())
  action    String   // e.g. "STATUS_UPDATE", "DELIVERY", "SYSTEM"
  details   String   // The description of what happened
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
}

model Message {
  id               String         @id @default(uuid())
  content          String
  createdAt        DateTime       @default(now())
  senderId         String
  sender           User           @relation(fields: [senderId], references: [id])
  serviceRequestId String
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id])
}
